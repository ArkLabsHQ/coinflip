{
  "name": "arkade-coinflip",
  "version": "0.3.13",
  "description": "Trustless coinflip betting protocol for Ark",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "import": "./dist/contract.js",
      "require": "./dist/contract.js"
    },
    "./arkade-win": {
      "types": "./dist/arkade-win.d.ts",
      "import": "./dist/arkade-win.js",
      "require": "./dist/arkade-win.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arkade-os/sdk": "file:../../vendor/arkade-os-sdk-0.4.32-arkade-script-1c02fac.tgz",
    "@arklabshq/contract-workflows-prototype": "file:../contract-workflows-prototype",
    "@noble/curves": "^1.6.0",
    "@scure/base": "^1.2.1",
    "@scure/btc-signer": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
